{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/text/v1/text",
                "template": {}
              }
            }
          }
        },
        {
          "title": "Title",
          "id": "title",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/title/v1/title",
                "template": {
                  "model": "title"
                }
              }
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/image/v1/image",
                "template": {}
              }
            }
          }
        },
        {
          "title": "Button",
          "id": "button",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/button/v1/button",
                "template": {
                  "model": "button"
                }
              }
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/section/v1/section",
                "template": {
                  "model": "section"
                }
              }
            }
          }
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": []
    },
    {
      "title": "Custom Form Components",
      "id": "custom-components",
      "components": [
        {
          "title": "Range",
          "id": "range",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/fd/components/form/numberinput/v1/numberinput",
                "template": {
                  "jcr:title": "Range",
                  "fieldType": "number-input",
                  "fd:viewType": "range",
                  "enabled": true,
                  "visible": true
                }
              }
            }
          }
        },
        {
          "title": "My custom card",
          "id": "my-custom-card",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/fd/components/form/radiobutton/v1/radiobutton",
                "template": {
                  "jcr:title": "My custom card",
                  "fieldType": "radio-group",
                  "enum": [
                    "0",
                    "1"
                  ],
                  "enumNames": [
                    "Item 1",
                    "Item 2"
                  ],
                  "orientation": "horizontal",
                  "fd:viewType": "my-custom-card"
                }
              }
            }
          }
        }
      ]
    }
  ]
}